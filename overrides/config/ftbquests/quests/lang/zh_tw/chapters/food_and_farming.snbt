	quest.18EADBAFC932F864.title: "剪毛時間"
	quest.1D2EF12FD7FDD217.quest_desc: ["母雞會生蛋。窩不確定牠們有沒有在做運動，但牠們生蛋的速度真的很拼。"]
	quest.1D2EF12FD7FDD217.quest_subtitle: "那是運動（Eggs-ercise）嗎？"
	quest.1D2EF12FD7FDD217.title: "窩不打算開雞蛋梗"
	quest.1D48298525EEADC9.quest_desc: ["你應該已經湊齊所有材料了。"]
	quest.1D48298525EEADC9.quest_subtitle: "幫窩加點糖！"
	quest.1D48298525EEADC9.title: "你好甜喔"
	quest.1DCAA0310AA55F1C.quest_desc: ["反正他下午五點就關門了，誰理他？"]
	quest.1DCAA0310AA55F1C.quest_subtitle: "釣魚大師的傳承"
	quest.1DCAA0310AA55F1C.title: "釣魚人生啟動"
	quest.1F114EB0AAB86DB4.quest_desc: ["市集方塊提供一個專屬村民。只要有綠寶石，他什麼種子都賣。 \\n\\n劇透：大部分東西都只要 1 顆綠寶石。他簡直是 10 元商店的老闆。"]
	quest.1F114EB0AAB86DB4.quest_subtitle: "村民的生法有很多種"
	quest.1F114EB0AAB86DB4.title: "購買農場物資"
	quest.2786D5AC19163524.quest_desc: ["這個方塊幫你的廚房開啟熔煉功能！"]
	quest.2786D5AC19163524.quest_subtitle: "不用計時器"
	quest.2786D5AC19163524.title: "親愛的，廚房裡有熔爐耶"
	quest.28C9EDBF6607E180.quest_desc: ["這是廚房的心臟。 \\n\\n它會顯示你身上或箱子裡所有的食材能做出什麼菜。 \\n\\n你終於可以在 Minecraft 裡蓋一個像樣的廚房了。"]
	quest.28C9EDBF6607E180.quest_subtitle: "吐司比某人還老 (國外梗)"
	quest.28C9EDBF6607E180.title: "這才是真正的廚房"
	quest.2E9C035EEE7E5C34.quest_desc: ["經典的栓繩。把動物拖回家吧。 \\n\\n這跟鉛礦不是同一種東西喔。"]
	quest.2E9C035EEE7E5C34.quest_subtitle: "老派作風"
	quest.2E9C035EEE7E5C34.title: "牛仔式放牧"
	quest.361DFDB1E1352D6B.quest_desc: ["去水邊找點甘蔗吧。"]
	quest.361DFDB1E1352D6B.title: "甜滋滋甘蔗"
	quest.37CA6F9F0226F10E.quest_desc: ["這個方塊用來存食材。 \\n\\n你還能把烤麵包機或罐裝乳牛擺在上面。"]
	quest.37CA6F9F0226F10E.quest_subtitle: "窩需要更大的料理空間"
	quest.37CA6F9F0226F10E.title: "空間不夠嗎？"
