{
	quest.01C0DC225CB25A0C.quest_subtitle: "獵人插件讓雷射會自動射怪"
	quest.01C0DC225CB25A0C.title: "暴力雷射"
	quest.02315D55EB638E3C.quest_subtitle: "做點生物質來發電"
