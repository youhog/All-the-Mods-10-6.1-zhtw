{
	quest.026C63594F813BCC.quest_desc: [
		"&l能力類型：&r 主動"
		""
		"&l能力功能：&r"
		""
		"啟動時清除身上所有的負面效果。有冷卻時間，別想著一直喝。"
	]
	quest.0272E58516A0C284.quest_desc: [
		"可用升級："
		"- 礦工 (Ore Miner)"
		"- 掃描儀 (Ore Scanner) &4&l已禁用&r&f"
		"- 除草機 (Lawnmower)"
		"- 除葉機 (Sky Sweeper)"
		"- 伐木工 (Tree Feller)"
		"- 葉片破壞者 (Leaf Breaker)"
		"- 自動熔煉 (Auto Smelter)"
		"- 鍛造槌 (Hammer)"
		"- 掉落物傳送 (Drops Teleporter)"
	]
	quest.02B0CCD5607FF3B5.quest_desc: ["「玩家存取器」就像是一個能遠端連動你背包的箱子。你可以設定它的各個面來連結你的背包、副手或是裝甲欄位。"]
	quest.02B8F50721F12CFF.quest_desc: [
		"&l能力類型：&r 被動"
		""
		"&l能力功能："
		""
		"防止掉落傷害。你的膝蓋會感謝這塊護墊的。"
	]
	quest.03ED9B0DFE8B4574.quest_desc: [
		"可用升級："
		"- 思想迷霧 (Mind Fog)"
		"- 昏厥 (Stupefy)"
		""
		"固有能力："
		"- 岩漿修復 (Lava Repair)"
	]
	quest.04A1D582003A0D9A.quest_desc: [
		"可用升級："
		"- 奔跑速度"
		"- 走路速度"
	]
	quest.05056CAA64E3971B.quest_desc: [
		"&l能力類型：&r 被動"
		""
		"&l能力功能：&r"
		""
		"讓射出去的箭矢附帶你藥水罐裡的藥水效果。這就是所謂的化學武器。"
	]
	quest.05D8C6EF8FCD6250.quest_desc: [
		"「原生膠 (Primogel Goo)」是 JDT 最基礎的黏液，用一些主世界的材料就能搓出來。"
		""
		"解鎖配方："
		"- 鐵芯 (Ferricore)"
		"- 原生煤炭 (Primal Coal)"
		""
		"黏液擴散範例："
		""
		"{image:atm:textures/questpics/justdirethings/goo_spread_ferricore.png width:200 height:200 align:center}"
	]
	quest.07655CA904354E9E.quest_desc: [
		"&l能力類型：&r 主動"
		""
		"&l能力功能：&r"
		""
		"啟動時把周圍的草跟花通通除掉。除草工人的福音。"
	]
	quest.079A415488A32076.quest_desc: ["「烈焰餘燼 (Blaze Ember)」是 JDT 的新材料。拿二階以上的黏液去感染原生煤炭塊就能得到。這礦石支援時運喔！"]
	quest.09485B63483B7A15.quest_desc: [
		"&l能力類型：&r 主動"
		""
		"&l能力功能：&r"
		""
		"暫時讓周圍的怪對你失去仇恨。簡單說就是隱身術（暫時版）。有冷卻時間。"
	]
	quest.09D2137B4F42006E.quest_desc: ["「蝕刻餘燼 (Eclipse Ember)」是 JDT 的頂級材料。拿四階黏液去感染虛火煤炭塊就能得到。同樣支援時運。"]
	quest.0A02DBE226C3F44E.quest_desc: [
		"可用升級："
		"- 思想迷霧"
		"- 昏厥"
		"- 夜視"
		"- 消除負面效果"
		"- 精神抹除"
	]
	quest.0B485DB737A036E9.quest_desc: ["機器設定複製器。讓你在不同機器之間複製貼上設定，懶人必備。"]
	quest.0B9BBE2A764631BF.quest_desc: ["簡單交換器可以把上面的物品、方塊、怪物甚至是玩家，瞬移到另一個相連的交換器。記得拿鐵芯扳手來連結它們。"]
	quest.0C1D55AA9CC902BD.quest_desc: [
		"可用升級："
		"- 除草機"
		"- 除葉機"
		"- 自動熔煉"
		"- 鍛造槌"
		"- 掉落物傳送"
	]
	quest.0C2EC56133D3CC6C.quest_desc: [
		"&l能力類型：&r 主動"
		""
		"&l能力功能：&r"
		""
		"暫時進入「無敵狀態」。這才是真正的開外掛。有冷卻時間。"
	]
	quest.0C9DD8E53A1B92C0.quest_desc: [
		"可用升級："
		"- 礦工"
		"- 自動熔煉"
		"- 鍛造槌"
		"- 掉落物傳送"
		"- X-Ray (透視)"
		"- 瞬間破壞"
	]
	quest.0CBFE2CE53DCACD5.quest_desc: [
		"&l能力類型：&r 被動"
		""
		"&l能力功能：&r"
		""
		"跳得更高。現在你可以當跳跳虎了。"
	]
	quest.0E3FDD8BB6D17A30.quest_desc: [
		"&l能力類型：&r 主動"
		""
		"&l能力功能：&r"
		""
		"啟動時把周圍的葉子通通拆掉。砍樹神技。"
	]
	quest.0FAF274ADA65B26A.quest_desc: ["「傳送門流體」是高級傳送門槍的生命之水。 \\n\\n把催化劑丟進多變流體會變成不穩定版（只能在終界存在）。拿三階以上的黏液去感染它，就能變回穩定的綠色果汁了。"]
	quest.120DCA89A919C7AF.quest_desc: [
		"&l能力類型：&r 被動"
		""
		"&l能力功能：&r"
		""
		"永久夜視。終於不用再插火把了。"
	]
	quest.1256F280F3669DDA.quest_desc: [
		"&l能力類型：&r 主動"
		""
		"&l能力功能：&r"
		""
		"讓射出去的箭矢在敵人之間「彈跳」。這招叫連鎖閃電箭。"
	]
	quest.132F4671E121C7B8.quest_desc: [
		"&l能力類型：&r 被動"
		""
		"&l能力功能：&r"
		""
		"走路變快。雖然只有一點點，但積少成多嘛。"
	]
	quest.16E02F671FBE9148.quest_desc: ["傳送門槍！左鍵射藍色、右鍵射橘色、Shift+右鍵關閉。你可以體會《傳送門》遊戲的感覺了。"]
	quest.1705175C20CE91DD.quest_desc: ["「蝕刻合金 (Eclipse Alloy)」是 JDT 的終極材料。拿四階黏液去感染獄髓塊就能得到。這就是財富自由的象徵。"]
	quest.1705175C20CE91DD.title: "蝕刻合金"
	quest.171DB70D0D19A942.quest_desc: [
		"&l能力類型：&r 被動"
		""
		"&l能力功能：&r"
		""
		"挖掉礦石後直接幫你燒成錠。這就是所謂的效率。"
	]
	quest.176A1CC43467EF23.quest_desc: [
		"可用升級："
		"- 自動墊步"
		"- 跳躍提升"
		"- 地震波 (Ground Stomp)"
		""
		"固有能力："
		"- 岩漿修復"
	]
	quest.17A9D2CA160561D9.quest_desc: [
		"&l能力類型：&r 被動"
		""
		"&l能力功能：&r"
		""
		"自動墊步。一格高的方塊直接走上去，不用再按跳了。"
	]
	quest.17C4F6EC1AFBC3AA.quest_desc: [
		"&l能力類型：&r 主動"
		""
		"&l能力功能：&r"
		"啟動時用粒子效果高亮顯示周圍的怪物。看誰還敢躲在轉角陰我。"
	]
	quest.18032636A60D0B2C.quest_desc: [
		"&l能力類型：&r 主動"
		""
		"&l能力功能：&r"
		""
		"掃描儀的升級版。啟動時直接「穿透牆壁」看到礦石。這才是真‧挖礦掛。"
	]
	quest.199388A311FAC14C.quest_desc: [
		"可用升級："
		"- 礦工"
		"- 掃描儀 &4&l已禁用&r&f"
		"- 自動熔煉"
		"- 鍛造槌"
		""
		"固有能力："
		"- 岩漿修復"
	]
	quest.19E6757F04098A0C.quest_desc: [
		"可用升級："
		"- 除草機"
		"- 除葉機"
	]
	quest.19E678E6EF9539DC.quest_desc: ["簡單感測器：偵測前方方塊，噴紅石訊號。有一個過濾格。"]
	quest.1B173E7533E1171F.quest_desc: ["簡單流體收集器。"]
	quest.1CBA0D7DA0558EBC.quest_desc: [
