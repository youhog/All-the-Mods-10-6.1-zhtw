	quest.74015945716FD10A.quest_subtitle: "可自訂的漏斗"
	quest.74AE214747A3DB1A.quest_desc: ["增加壓力的上限。"]
	quest.74AE214747A3DB1A.quest_subtitle: "轉大聲點！"
	quest.75D3F3C1D4A3EAA2.quest_desc: ["想搬運熱量？做點 &3熱量管&r 吧。"]
	quest.75D3F3C1D4A3EAA2.quest_subtitle: "我們有熱量可以搬了 :)"
	quest.75D3F3C1D4A3EAA2.title: "輸送熱量"
	quest.762B8309E1A31B99.quest_desc: ["每顆加防禦跟韌性。"]
	quest.762B8309E1A31B99.quest_subtitle: "最大數量：4"
	quest.7770F0D62457096D.quest_desc: ["無人機雖然很強但這任務不教你。自己去研究啦！"]
	quest.7770F0D62457096D.title: "無人機程式設計"
