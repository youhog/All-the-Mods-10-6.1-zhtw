	quest.72C09FD89C28B1EC.title: "煉油廠"
	quest.7386A8433698946C.quest_desc: ["物品搜尋升級。幫你找附近箱子或地上的東西。要配上追蹤器才會動喔。"]
	quest.7386A8433698946C.quest_subtitle: "最大數量：1"
	quest.7395B41685F4BC1A.quest_desc: ["&3電力壓縮機&r：把 FE 轉成壓力。如果你電多到沒地方花，這是生壓最快的方法。"]
	quest.7395B41685F4BC1A.quest_subtitle: "電力變壓力"
	quest.7395B41685F4BC1A.title: "電力氣壓機"
