	quest.1DC407272D9D9CCE.quest_subtitle: "覺醒合成"
	quest.1DC407272D9D9CCE.title: "覺醒超髓蜂"
	quest.1DF026030780AE96.quest_subtitle: "從蜂箱裡的蜜蜂身上榨取基因"
	quest.1E9BD4B74DAEA9FC.quest_desc: ["這款蜂巢不吃蜂蜜點心，牠吃爆裂紫頌果。真是有夠挑。"]
	quest.1E9BD4B74DAEA9FC.quest_subtitle: "放在終界引誘終界蜂"
	quest.1EBD5E4410A6DF34.quest_subtitle: "餵幽靈蜂魂髓匕首"
	quest.1EBD5E4410A6DF34.title: "魂髓蜂"
	quest.205DE46ABA1CCC8F.quest_subtitle: "在合金熔煉爐製作"
	quest.205DE46ABA1CCC8F.title: "導電合金蜂"
	quest.2086C73688C8BA51.quest_subtitle: "餵熔岩蜂一桶硫酸"
	quest.2086C73688C8BA51.title: "硫酸蜂"
	quest.2182492BCC1B33D8.quest_desc: ["裝在蜂箱裡，每次產蜜有 5% 機率多生一隻寶寶。\\n\\n這就是全自動增產報國。"]
	quest.2182492BCC1B33D8.quest_subtitle: "多子多孫多福氣"
