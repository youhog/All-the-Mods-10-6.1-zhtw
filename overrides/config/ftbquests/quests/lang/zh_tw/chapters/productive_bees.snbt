	quest.0CD6F30BBEE20E15.title: "精煉螢石蜂"
	quest.0D5D76B3551CD5A7.quest_desc: ["沒錯，牠就叫鋁蜂。"]
	quest.0D5D76B3551CD5A7.quest_subtitle: "結晶 + 灰燼採礦"
	quest.0D5D76B3551CD5A7.title: "鋁蜂"
