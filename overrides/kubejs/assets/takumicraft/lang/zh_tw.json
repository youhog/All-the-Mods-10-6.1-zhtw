    "entity.takumicraft.silentcreeper": "靜默苦力怕",
    "entity.takumicraft.silentcreeper.desc": "它来了，它悄悄地来了。不帶来一丝声响，却帶走你的性命。",
    "entity.takumicraft.silentcreeper.read": "",
    "entity.takumicraft.skeletoncreeper": "骷髏苦力怕",
