    "entity.takumicraft.spidercreeper": "蜘蛛苦力怕",
    "entity.takumicraft.spidercreeper.desc": "習得忍術的这類苦力怕寄居在天花板材和墙缝裡，可谓是能重裝房屋的一大害虫。",
    "entity.takumicraft.spidercreeper.read": "",
    "entity.takumicraft.squidcreeper": "魷魚苦力怕",
    "entity.takumicraft.squidcreeper.desc": "绿色的魷魚，充滿爆炸性。像水雷一樣麻烦。",
    "entity.takumicraft.squidcreeper.read": "",
    "entity.takumicraft.stonecreeper": "石頭苦力怕",
    "entity.takumicraft.stonecreeper.desc": "爆炸時對石頭特攻。使洞窟在爆炸的風暴中轰然倒塌。",
    "entity.takumicraft.stonecreeper.read": "",
    "entity.takumicraft.straycreeper": "流浪者苦力怕",
